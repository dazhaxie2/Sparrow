# Sparrow MySQL 8.0 — Phase 3 tuning for 10k QPS 包络 / 10M 用户
# 基线假设:Docker 容器可用 ~6GB 内存,数据集 = 10M 用户 + 万级图谱节点
# 说明:Phase 2 原为 1000 QPS / buffer_pool 1G / max_conn 500;Phase 3 抬到 10k QPS 包络。
#       若宿主机内存不足,可临时把 buffer_pool_size 降回 1G、buffer_pool_instances 降回 4。

[mysqld]
# ── 基础 ──
character-set-server = utf8mb4
collation-server     = utf8mb4_unicode_ci
skip-name-resolve    = ON               # 跳过 DNS 反查,降低连接开销
default-time-zone    = '+08:00'

# ── 连接 ──
max_connections         = 1500           # 4 服务 ×50 池(多实例再放大)+ Seata + admin + 余量
wait_timeout            = 28800
interactive_timeout     = 28800
thread_cache_size       = 100            # 10k QPS 下避免频繁建/销线程
table_open_cache        = 4000           # 热表多并发打开
table_definition_cache  = 2000
max_prepared_stmt_count = 65535          # prep stmt 缓存上限,配合 JDBC cachePrepStmts

# ── InnoDB 缓冲池 ──
innodb_buffer_pool_size  = 4G            # 容纳热数据:10M 用户索引 + 图谱全量
innodb_buffer_pool_instances = 8
innodb_data_file_path    = ibdata1:1G:autoextend

# ── InnoDB 日志 ──
innodb_log_file_size     = 1G            # 10k QPS 写入下,大日志减少 checkpoint 压力
innodb_log_buffer_size   = 128M
innodb_flush_log_at_trx_commit = 2       # 压测/非金融场景:每秒刷盘(生产改 1)
innodb_flush_method      = O_DIRECT      # 绕过 OS page cache,避免 double buffer

# ── InnoDB 并发 ──
innodb_read_io_threads   = 8
innodb_write_io_threads  = 8
innodb_purge_threads     = 4
innodb_io_capacity       = 2000          # SSD 估算 IOPS 余量
innodb_io_capacity_max   = 4000

# ── 临时表 / 排序 ──
tmp_table_size     = 256M
max_heap_table_size = 256M
sort_buffer_size   = 4M
read_buffer_size   = 4M

# ── 慢查询 ──
slow_query_log      = ON
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time     = 0.2               # 记录 >200ms 的查询
log_queries_not_using_indexes = OFF      # 压测时关闭,避免日志洪水

# ── binlog (Seata / CDC 需要) ──
log_bin             = mysql-bin
binlog_format       = ROW
binlog_expire_logs_seconds = 86400
