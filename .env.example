# LLM 配置(智谱 BigModel,OpenAI 兼容)
# 标准端点 /api/paas/v4 扣减按量资源包;/api/coding/paas/v4 走独立的 Coding 包月套餐
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=your_api_key_here
AI_CHAT_MODEL=glm-4.7
AI_EMBEDDING_MODEL=embedding-3

# sparrow-ai 与 sparrow-industry-chain 的内部模型池鉴权令牌；两端必须一致且至少 32 字符。
# 仅在本地 .env 或外部密钥存储中配置，禁止提交真实值。
SPARROW_MODEL_POOL_INTERNAL_TOKEN=

# MySQL 配置
# 密码无默认值,docker-compose 强制注入(缺失即报错);初始化数据卷后改密码需重建卷。
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
MYSQL_USER=sparrow
MYSQL_PASSWORD=change_me_strong_app_password
MYSQL_BUFFER_POOL=512M

# Neo4j 配置(图谱存储)
NEO4J_PASSWORD=change_me_neo4j_password

# Minio 配置(AI 层对象存储)
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key

# 交易服务配置
TRADE_FAIL_AFTER_MEMBERSHIP_GRANT=false

# 产业链研究配置
CHAIN_RESEARCH_FREE_PER_DAY=1
CHAIN_RESEARCH_MEMBER_PER_DAY=10
CHAIN_RESEARCH_REQUEST_TIMEOUT_SECONDS=180
CHAIN_RESEARCH_MAX_RETRIES=2
CHAIN_RESEARCH_SEARCH_URL=https://m.sogou.com/web/searchList.jsp

# 邮箱验证码登录发件箱(QQ SMTP)— sparrow-user 使用
# MAIL_USERNAME 用完整 @qq.com 地址;MAIL_PASSWORD 是 QQ 邮箱 SMTP 授权码(非登录密码)
MAIL_USERNAME=3267044027@qq.com
MAIL_PASSWORD=your_qq_smtp_auth_code_here
SPARROW_ADMIN_EMAIL=

# 模型配置管理 AES-GCM 主密钥(base64,32 字节)— sparrow-industry-chain 使用
# 用于加密存储在 model_config 表的 LLM API Key。生成:openssl rand -base64 32
SPARROW_CRYPTO_MODEL_CONFIG_SECRET=your_base64_32byte_secret_here

# 爬虫配置
SPIDER_LIMIT=20
SPIDER_WIKI_API=https://zh.wikipedia.org/w/api.php
SPIDER_WIKI_FALLBACK_API=https://en.wikipedia.org/w/api.php
SPIDER_PROXY=

# 前端 API 基础路径(实际应配置在 frontend/.env 文件中)
VITE_API_BASE=
